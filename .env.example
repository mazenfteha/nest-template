# ─────────────────────────────────────────────────────────────
# Environment template. Copy to the file matching your NODE_ENV:
#   cp .env.example .env.staging      # then fill real values
#   cp .env.example .env.production
# The app loads `.env.${NODE_ENV}` first, then `.env` as fallback.
# Real process env vars (e.g. injected by your host) take precedence.
# ─────────────────────────────────────────────────────────────

# development | staging | production | test
NODE_ENV=development

# HTTP
PORT=3000
API_PREFIX=api
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_template?schema=public

# JWT — access secret MUST be at least 32 characters
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# Optional: default admin created by `npm run db:seed`
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
